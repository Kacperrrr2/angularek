# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/cache
.nx/workspace-data
.nx/migrate-runs
.claude/worktrees
.claude/settings.local.json

.angular

__screenshots__/

# Python
__pycache__/
*.py[cod]
*$py.class

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python build artifacts
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Python test, coverage and type-check caches
.pytest_cache/
.mypy_cache/
.pyre/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# Python runtime and local env files
*.log
*.sqlite3
*.db
.env
.env.*
!.env.example

# Machine-local CA cert for Docker builds behind TLS-inspecting antivirus/proxy (see docker/certs/)
docker/certs/*
!docker/certs/.gitkeep
