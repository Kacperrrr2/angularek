{
  "name": "adk-agent",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/adk-agents/triz_agent",
  "implicitDependencies": ["mcp-server"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "uv run adk api_server triz_agent --port 8081 --host 0.0.0.0",
        "cwd": "apps/adk-agents"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -t triz-adk-agent .",
        "cwd": "apps/adk-agents"
      }
    }
  },
  "tags": ["type:agent", "scope:triz"]
}
